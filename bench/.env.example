# Copy to `.env` and edit. `docker compose` and the scripts read these.

# --- chain under test -------------------------------------------------------------------------
# Index prefix. WAX is our primary test chain, but the reader + this stack are chain-agnostic:
# set this to eos, telos, ux, proton, ... and point the reader at that chain's state-history.
CHAIN=wax
# Index version + partition size — must match how you intend to query (mirrors Hyperion config).
INDEX_VERSION=v1
INDEX_PARTITION_SIZE=10000000

# --- Elasticsearch / Kibana -------------------------------------------------------------------
ELASTIC_VERSION=8.15.3
ES_PORT=9200
KIBANA_PORT=5601
# JVM heap. Use ~50% of the RAM you give the bench box (and no more than ~31g). Bump for big runs.
# Quote it — the value contains a space (so `source .env` and docker compose both handle it).
ES_JAVA_OPTS="-Xms4g -Xmx4g"
# Where the loader/scripts reach ES (from the host).
ES=http://localhost:9200

# --- full write-path services (docker compose --profile full up -d) ---------------------------
AMQP_USER=hyperion
AMQP_PASS=hyperion
AMQP_VHOST=hyperion
AMQP_PORT=5672
AMQP_MGMT_PORT=15672
REDIS_PORT=6379
