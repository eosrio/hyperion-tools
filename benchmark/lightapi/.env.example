# Copy to `.env` and adjust. All values have sensible defaults in docker-compose.yml.

# Libre portable snapshot (Spring/vanilla compatible). Both stacks consume this same file.
SNAPSHOT_URL=https://snapshots.eosusa.io/snaps/libre/libre-2026-06-01_00-00.tar.gz

# Extra Libre p2p peers (OPTIONAL). The cc32d9 nodeos already ships a bundled set of Libre seed peers
# (cc32d9/nodeos/config.ini), so the stack works out of the box. Add more here if those go stale —
# comma/space-separated host:port. (Only the cc32d9 stack uses peers; our stack reads the snapshot
# directly and needs none.)
#   LIBRE_P2P_PEERS=p2p.libre.cryptobloks.io:9876, libre-seed.eosiomadrid.io:9877
LIBRE_P2P_PEERS=

# Host port mappings
OURS_PORT=7000
CC32D9_PORT=5001
MONGO_PORT=27017
NODEOS_HTTP_PORT=8888
