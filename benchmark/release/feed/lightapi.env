# WormDB Light API — SHiP feed configuration (read by the lightapi-feed systemd service).
# Point these at YOUR node + chain, then:  systemctl restart lightapi-feed   (or --user)

# Node State-History websocket  (the node's `state-history-endpoint`):
SHIP=ws://127.0.0.1:8080/
# Node chain HTTP API  (the node's `http-server-address`):
CHAIN_API=http://127.0.0.1:8888
# Must match the `chain` in wormdb.json:
CHAIN=wax
# System token and its contract:
SYSTOKEN=WAX
SYSCONTRACT=eosio.token
# WormDB's WormWire port — server.port in wormdb.json (default 6389). NOT the HTTP :6390.
PORT=6389
# Block to stream from. For the FIRST run after building the segment, set this to the head block_num
# that snapshot-load printed, so the gap since the snapshot is filled. 0 = start at the node's current
# LIB (fine once the segment is current, and for restarts).
START=0
